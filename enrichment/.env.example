# Shared LiteLLM gateway for Claude and Gemini.
# If your gateway uses one shared key, set LITELLM_API_KEY and leave the tool-specific keys blank.
LITELLM_BASE_URL=https://llm.lazertechnologies.com
LITELLM_API_KEY=

# Claude
# For LiteLLM, set CLAUDE_MODEL to your LiteLLM model alias, often something like anthropic/claude-*
# For direct Anthropic usage, leave LITELLM_BASE_URL blank and set ANTHROPIC_API_KEY instead.
CLAUDE_MODEL=anthropic/claude-haiku-4-5-20250415
CLAUDE_API_KEY=
ANTHROPIC_API_KEY=

# Gemini
# For LiteLLM, set GEMINI_MODEL to your LiteLLM model alias, often something like gemini/gemini-*
# For direct Google usage, leave LITELLM_BASE_URL blank and set GOOGLE_GENAI_API_KEY instead.
GEMINI_MODEL=gemini/gemini-2.5-flash
GEMINI_API_KEY=
GOOGLE_GENAI_API_KEY=

# Firecrawl
FIRECRAWL_API_KEY=

# Perplexity
PERPLEXITY_BASE_URL=https://api.perplexity.ai
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar-pro
