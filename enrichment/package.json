{
  "name": "enrichment",
  "version": "1.0.0",
  "description": "Product enrichment evaluation - data processing pipeline",
  "type": "module",
  "engines": {
    "node": ">=25.0.0"
  },
  "scripts": {
    "test": "vitest run --reporter=verbose",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "parse-and-clean": "tsx src/scripts/parse-and-clean.ts",
    "cache-images": "tsx src/scripts/cache-images.ts",
    "enrich": "tsx src/scripts/enrich.ts",
    "enrich:llm": "tsx src/scripts/enrich.ts --tool all-llm"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@google/genai": "^1.45.0",
    "@mendable/firecrawl-js": "^4.16.0",
    "openai": "^6.27.0",
    "p-limit": "^7.3.0",
    "papaparse": "^5.5.3",
    "sharp": "^0.34.5",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/papaparse": "^5.5.2",
    "@types/sharp": "^0.31.1",
    "@vitest/coverage-v8": "^4.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
